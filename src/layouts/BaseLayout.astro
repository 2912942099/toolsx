---
import '../styles/global.css';
const { title, description } = Astro.props;
const pageTitle = title ? `${title} — ToolsX` : 'ToolsX — Free Online Tools';
const desc = description || 'Fast, free online tools. JSON formatter, Base64, color converter, hash generator, and more. Everything runs in your browser.';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6646632276289644"
     crossorigin="anonymous"></script>
  
  <script>
(function(){
    var bp = document.createElement('script');
    bp.src = 'https://zz.bdstatic.com/linksubmit/push.js';
    var s = document.getElementsByTagName("script")[0];
    if (s && s.parentNode) {
        s.parentNode.insertBefore(bp, s);
    } else {
        document.head.appendChild(bp);
    }
})();
</script>

  
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={desc} />
  <meta name="robots" content="index, follow" />
  <meta name="baidu-site-verification" content="codeva-3jNkyGby9R" />
  <meta name="google-site-verification" content="XtA1d-XceBYw4dDcu4y7LKZbKpXnuzSnjXXgHwjn3VU" />
  <meta name="msvalidate.01" content="7085DD25CAF383479F913F516569ABE5" />
<meta property="og:type" content="website" />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={desc} />
<meta property="og:url" content="https://www.kongbyte.top" />
<meta property="og:site_name" content="KongByte" />
<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={desc} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=JetBrains+Mono:wght@400;500;600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a href="/" class="site-logo">&lt;<span>Tools</span>X/&gt;</a>
      <nav class="site-nav">
        <a href="/" data-t="nav_tools">All Tools</a>
        <button id="langBtn" class="lang-btn" title="Switch language">EN / 中</button>
      </nav>
    </div>
  </header>

  <main class="container">
    <slot />
  </main>

<footer class="site-footer">
  <div class="container">
    <p>&copy; {new Date().getFullYear()} ToolsX. <a href="/privacy" data-t="nav_privacy">Privacy Policy</a></p>
  </div>
</footer>



