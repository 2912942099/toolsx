    <header class="site-header">
      <div class="container">
        <a href="/" class="site-logo">&lt;<span>Tools</span>X/&gt;</a>
        <nav class="site-nav">
          <a href="/" data-t="nav_tools">All Tools</a>
          <button id="langBtn" class="lang-btn" title="Switch language"
            >EN / 中</button
          >
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>
          &copy; {new Date().getFullYear()} ToolsX. <a
            href="/privacy"
            data-t="nav_privacy">Privacy Policy</a>
