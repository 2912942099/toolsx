            ts_formats_title: "Timestamp Formats",
            ts_formats_text:
              "Seconds (10 digits): 1700000000 represents November 14, 2023. Milliseconds (13 digits): 1700000000000 represents the same moment with higher precision. ISO 8601 format (2023-11-14T00:00:00Z) is the international standard for date-time representation.",

            ip_how_title: "How to Use",
            ip_how_text:
              'Click "My IP" to automatically detect your public IP address and geolocation. Or enter any IP address in the input field and click "Lookup" to see its location, ISP, timezone, and other details.',
            ip_what_title: "What is an IP Address?",
            ip_what_text:
