---
import "../styles/global.css";
const { title, description } = Astro.props;
const pageTitle = title ? `${title} — ToolsX` : "ToolsX — Free Online Tools";
const desc =
  description ||
  "Fast, free online tools. JSON formatter, Base64, color converter, hash generator, and more. Everything runs in your browser.";
