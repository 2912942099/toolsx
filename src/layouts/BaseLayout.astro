        window.__devtoolsMergeDict = function (extra) {
          if (extra.en) Object.keys(extra.en).forEach(function (k) { dict.en[k] = extra.en[k]; });
          if (extra.zh) Object.keys(extra.zh).forEach(function (k) { dict.zh[k] = extra.zh[k]; });
        };

        function getLang() {
          var saved = localStorage.getItem(KEY);
          if (saved) return saved;
          var browserLang = navigator.language || navigator.userLanguage || "en";
          if (browserLang.toLowerCase().indexOf("zh") === 0) return "zh";
          return "en";
        }

        function applyLang(lang) {
          document.querySelectorAll("[data-t]").forEach(function (el) {
            var key = el.getAttribute("data-t");
            if (dict[lang] && dict[lang][key]) {
              el.textContent = dict[lang][key];
            }
          });
          document.querySelectorAll("[data-t-zh]").forEach(function (el) {
            if (lang === "zh") {
              el.textContent = el.getAttribute("data-t-zh");
            } else {
              var enText = el.getAttribute("data-t-en");
              if (enText) el.textContent = enText;
            }
          });
          document.querySelectorAll("[data-t-ph]").forEach(function (el) {
            var key = el.getAttribute("data-t-ph");
            if (dict[lang] && dict[lang][key]) {
              el.placeholder = dict[lang][key];
            }
          });
          var btn = document.getElementById("langBtn");
          if (btn) btn.textContent = lang === "en" ? "EN / 中" : "中 / EN";
        }

        window.__devtools = window.__devtools || {};
        window.__devtools.getLang = getLang;
        window.__devtools.dict = dict;
        window.__devtools.applyLang = applyLang;

        var btn = document.getElementById("langBtn");
        if (btn) {
          btn.addEventListener("click", function () {
            var next = getLang() === "en" ? "zh" : "en";
            localStorage.setItem(KEY, next);
            applyLang(next);
          });
        }

function showContent() {
  var loader = document.getElementById('langLoader');
  var main = document.querySelector('main');
  if (loader) loader.style.display = 'none';
  if (main) main.classList.remove('lang-loading');
}

applyLang(getLang());
showContent();

document.addEventListener('DOMContentLoaded', function() {
  applyLang(getLang());
  showContent();
});




