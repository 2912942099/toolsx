---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Hash Generator" description="Generate MD5, SHA-1, SHA-256, SHA-512 hashes from text. Free online tool.">
  <div class="tool-page">
    <div class="tool-header">
      <h1 data-t="md5_title">Hash Generator</h1>
      <p data-t="md5_desc">Generate MD5, SHA-1, SHA-256, SHA-512 hashes from text.</p>
    </div>

    <div class="editor-label" data-t="input_label">Input</div>
    <textarea id="hashInput" placeholder="Enter text to hash..." data-t-ph="ph_md5_input" style="min-height:140px"></textarea>

    <div class="hash-options">
      <div class="option-row">
        <input type="checkbox" id="uppercase" />
        <label for="uppercase" data-t="lbl_uppercase">Uppercase output</label>
      </div>
    </div>

    <div id="hashResults" class="hash-list">
      <div class="hash-item">
        <div class="hash-algo">MD5</div>
        <div class="hash-value-row">
          <code class="hash-val" id="h_md5">—</code>
          <button class="hex-copy" data-target="h_md5" data-t="btn_copy">Copy</button>
        </div>
      </div>
      <div class="hash-item">
        <div class="hash-algo">SHA-1</div>
        <div class="hash-value-row">
          <code class="hash-val" id="h_sha1">—</code>
          <button class="hex-copy" data-target="h_sha1" data-t="btn_copy">Copy</button>
        </div>
      </div>
      <div class="hash-item">
        <div class="hash-algo">SHA-256</div>
        <div class="hash-value-row">
          <code class="hash-val" id="h_sha256">—</code>
          <button class="hex-copy" data-target="h_sha256" data-t="btn_copy">Copy</button>
        </div>
      </div>
      <div class="hash-item">
        <div class="hash-algo">SHA-512</div>
        <div class="hash-value-row">
          <code class="hash-val" id="h_sha512">—</code>
          <button class="hex-copy" data-target="h_sha512" data-t="btn_copy">Copy</button>
        </div>
      </div>
    </div>

    <div class="hash-compare">
      <div class="option-row" style="margin-bottom:12px;">
        <input type="checkbox" id="compareToggle" />
        <label for="compareToggle" data-t="lbl_compare">Compare with known hash</label>
      </div>
      <div id="compareArea" style="display:none;">
        <div class="hash-compare-input">
          <input type="text" id="compareHash" placeholder="Paste a hash to compare..." data-t-ph="ph_md5_compare" spellcheck="false" />
          <span id="compareResult" class="hash-compare-result"></span>
        </div>
      </div>
    </div>

    <section class="tool-info">
      <h2 data-t="md5_about">About Hash Functions</h2>
      <p data-t="md5_about_text">A hash function converts input data into a fixed-size string of characters. MD5 produces a 128-bit hash (32 hex chars). SHA-1 produces a 160-bit hash (40 hex chars). SHA-256 produces a 256-bit hash (64 hex chars). SHA-512 produces a 512-bit hash (128 hex chars). These are one-way functions — you cannot reverse a hash back to the original text.</p>
      <h3 data-t="md5_how_title">How to Use</h3>
      <p data-t="md5_how_text">Enter or paste your text in the input field. The tool automatically generates MD5, SHA-1, SHA-256, and SHA-512 hashes simultaneously. Click the copy button next to any hash to copy it to your clipboard. Use the compare feature to verify a hash against a known value.</p>
      <h3 data-t="md5_what_title">What is a Hash Function?</h3>
      <p data-t="md5_what_text">A hash function takes input data of any size and produces a fixed-size string of characters. The same input always produces the same hash, but you cannot reverse the process to get the original data from the hash. This makes hash functions ideal for data integrity verification and password storage.</p>
      <h3 data-t="md5_choosing_title">Which Hash to Choose?</h3>
      <p data-t="md5_choosing_text">MD5 (32 chars): Fast but not collision-resistant. Use for checksums and non-security purposes. SHA-1 (40 chars): Stronger than MD5 but deprecated for security use. SHA-256 (64 chars): Industry standard for security. Used in SSL certificates and blockchain. SHA-512 (128 chars): Strongest option with highest collision resistance.</p>
    </section>
  </div>

  <!-- Hash Generator 页面专属翻译 -->
  <script is:inline>
    (function() {
      if (window.__devtoolsMergeDict) {
        window.__devtoolsMergeDict({
          en: {
            md5_title: 'Hash Generator',
            md5_desc: 'Generate MD5, SHA-1, SHA-256, SHA-512 hashes from text.',
            md5_about: 'About Hash Functions',
            md5_about_text: 'A hash function converts input data into a fixed-size string of characters. MD5 produces a 128-bit hash (32 hex chars). SHA-1 produces a 160-bit hash (40 hex chars). SHA-256 produces a 256-bit hash (64 hex chars). SHA-512 produces a 512-bit hash (128 hex chars). These are one-way functions — you cannot reverse a hash back to the original text.',
            md5_how_title: 'How to Use',
            md5_how_text: 'Enter or paste your text in the input field. The tool automatically generates MD5, SHA-1, SHA-256, and SHA-512 hashes simultaneously. Click the copy button next to any hash to copy it to your clipboard. Use the compare feature to verify a hash against a known value.',
            md5_what_title: 'What is a Hash Function?',
            md5_what_text: 'A hash function takes input data of any size and produces a fixed-size string of characters. The same input always produces the same hash, but you cannot reverse the process to get the original data from the hash. This makes hash functions ideal for data integrity verification and password storage.',
            md5_choosing_title: 'Which Hash to Choose?',
            md5_choosing_text: 'MD5 (32 chars): Fast but not collision-resistant. Use for checksums and non-security purposes. SHA-1 (40 chars): Stronger than MD5 but deprecated for security use. SHA-256 (64 chars): Industry standard for security. Used in SSL certificates and blockchain. SHA-512 (128 chars): Strongest option with highest collision resistance.',
            ph_md5_input: 'Enter text to hash...',
            ph_md5_compare: 'Paste a hash to compare...',
          },
          zh: {
            md5_title: 'MD5 / SHA 哈希生成',
            md5_desc: '生成 MD5、SHA-1、SHA-256、SHA-512 哈希值。',
            md5_about: '关于哈希函数',
            md5_about_text: '哈希函数将输入数据转换为固定长度的字符串。MD5 生成 128 位哈希值（32个十六进制字符）。SHA-1 生成 160 位哈希值（40个字符）。SHA-256 生成 256 位哈希值（64个字符）。SHA-512 生成 512 位哈希值（128个字符）。这些都是单向函数——无法从哈希值反推出原始文本。',
            md5_how_title: '如何使用',
            md5_how_text: '在输入框中输入或粘贴文本。工具会同时自动生成 MD5、SHA-1、SHA-256 和 SHA-512 哈希值。点击任意哈希值旁边的复制按钮将其复制到剪贴板。使用对比功能验证哈希值是否与已知值匹配。',
            md5_what_title: '什么是哈希函数？',
            md5_what_text: '哈希函数接收任意大小的输入数据，生成固定长度的字符串。相同的输入总是产生相同的哈希值，但无法从哈希值反向推导出原始数据。这使得哈希函数非常适合用于数据完整性验证和密码存储。',
            md5_choosing_title: '应该选择哪种哈希？',
            md5_choosing_text: 'MD5（32 字符）：速度快但不抗碰撞。用于校验和非安全场景。SHA-1（40 字符）：比 MD5 更强但已不推荐用于安全场景。SHA-256（64 字符）：安全行业标准，用于 SSL 证书和区块链。SHA-512（128 字符）：最强选项，碰撞抗性最高。',
            ph_md5_input: '输入要哈希的文本...',
            ph_md5_compare: '粘贴哈希值进行对比...',
          }
        });
        if (window.__devtools && window.__devtools.applyLang) {
          window.__devtools.applyLang(window.__devtools.getLang());
        }
      }
    })();
  </script>

  <!-- 功能逻辑 -->
  <script is:inline>
    // MD5 Implementation (RFC 1321)
    var MD5 = (function() {
      function safeAdd(x, y) {
        var lsw = (x & 0xFFFF) + (y & 0xFFFF);
        var msw = (x >> 16) + (y >> 16) + (lsw >> 16);
        return (msw << 16) | (lsw & 0xFFFF);
      }
      function bitRotateLeft(num, cnt) {
        return (num << cnt) | (num >>> (32 - cnt));
      }
      function md5cmn(q, a, b, x, s, t) {
        return safeAdd(bitRotateLeft(safeAdd(safeAdd(a, q), safeAdd(x, t)), s), b);
      }
      function md5ff(a,b,c,d,x,s,t){ return md5cmn((b&c)|((~b)&d),a,b,x,s,t); }
      function md5gg(a,b,c,d,x,s,t){ return md5cmn((b&d)|(c&(~d)),a,b,x,s,t); }
      function md5hh(a,b,c,d,x,s,t){ return md5cmn(b^c^d,a,b,x,s,t); }
      function md5ii(a,b,c,d,x,s,t){ return md5cmn(c^(b|(~d)),a,b,x,s,t); }
      function binlMD5(x, len) {
        x[len >> 5] |= 0x80 << (len % 32);
        x[((len + 64) >>> 9 << 4) + 14] = len;
        var a=1732584193, b=-271733879, c=-1732584194, d=271733878;
        for(var i=0;i<x.length;i+=16){
          var olda=a,oldb=b,oldc=c,oldd=d;
          a=md5ff(a,b,c,d,x[i],7,-680876936);d=md5ff(d,a,b,c,x[i+1],12,-389564586);c=md5ff(c,d,a,b,x[i+2],17,606105819);b=md5ff(b,c,d,a,x[i+3],22,-1044525330);
          a=md5ff(a,b,c,d,x[i+4],7,-176418897);d=md5ff(d,a,b,c,x[i+5],12,1200080426);c=md5ff(c,d,a,b,x[i+6],17,-1473231341);b=md5ff(b,c,d,a,x[i+7],22,-45705983);
          a=md5ff(a,b,c,d,x[i+8],7,1770035416);d=md5ff(d,a,b,c,x[i+9],12,-1958414417);c=md5ff(c,d,a,b,x[i+10],17,-42063);b=md5ff(b,c,d,a,x[i+11],22,-1990404162);
          a=md5ff(a,b,c,d,x[i+12],7,1804603682);d=md5ff(d,a,b,c,x[i+13],12,-40341101);c=md5ff(c,d,a,b,x[i+14],17,-1502002290);b=md5ff(b,c,d,a,x[i+15],22,1236535329);
          a=md5gg(a,b,c,d,x[i+1],5,-165796510);d=md5gg(d,a,b,c,x[i+6],9,-1069501632);c=md5gg(c,d,a,b,x[i+11],14,643717713);b=md5gg(b,c,d,a,x[i],20,-373897302);
          a=md5gg(a,b,c,d,x[i+5],5,-701558691);d=md5gg(d,a,b,c,x[i+10],9,38016083);c=md5gg(c,d,a,b,x[i+15],14,-660478335);b=md5gg(b,c,d,a,x[i+4],20,-405537848);
          a=md5gg(a,b,c,d,x[i+9],5,568446438);d=md5gg(d,a,b,c,x[i+14],9,-1019803690);c=md5gg(c,d,a,b,x[i+3],14,-187363961);b=md5gg(b,c,d,a,x[i+8],20,1163531501);
          a=md5gg(a,b,c,d,x[i+13],5,-1444681467);d=md5gg(d,a,b,c,x[i+2],9,-51403784);c=md5gg(c,d,a,b,x[i+7],14,1735328473);b=md5gg(b,c,d,a,x[i+12],20,-1926607734);
          a=md5hh(a,b,c,d,x[i+5],4,-378558);d=md5hh(d,a,b,c,x[i+8],11,-2022574463);c=md5hh(c,d,a,b,x[i+11],16,1839030562);b=md5hh(b,c,d,a,x[i+14],23,-35309556);
          a=md5hh(a,b,c,d,x[i+1],4,-1530992060);d=md5hh(d,a,b,c,x[i+4],11,1272893353);c=md5hh(c,d,a,b,x[i+7],16,-155497632);b=md5hh(b,c,d,a,x[i+10],23,-1094730640);
          a=md5hh(a,b,c,d,x[i+13],4,681279174);d=md5hh(d,a,b,c,x[i],11,-358537222);c=md5hh(c,d,a,b,x[i+3],16,-722521979);b=md5hh(b,c,d,a,x[i+6],23,76029189);
          a=md5hh(a,b,c,d,x[i+9],4,-640364487);d=md5hh(d,a,b,c,x[i+12],11,-421815835);c=md5hh(c,d,a,b,x[i+15],16,530742520);b=md5hh(b,c,d,a,x[i+2],23,-995338651);
          a=md5ii(a,b,c,d,x[i],6,-198630844);d=md5ii(d,a,b,c,x[i+7],10,1126891415);c=md5ii(c,d,a,b,x[i+14],15,-1416354905);b=md5ii(b,c,d,a,x[i+5],21,-57434055);
          a=md5ii(a,b,c,d,x[i+12],6,1700485571);d=md5ii(d,a,b,c,x[i+3],10,-1894986606);c=md5ii(c,d,a,b,x[i+10],15,-1051523);b=md5ii(b,c,d,a,x[i+1],21,-2054922799);
          a=md5ii(a,b,c,d,x[i+8],6,1873313359);d=md5ii(d,a,b,c,x[i+15],10,-30611744);c=md5ii(c,d,a,b,x[i+6],15,-1560198380);b=md5ii(b,c,d,a,x[i+13],21,1309151649);
          a=md5ii(a,b,c,d,x[i+4],6,-145523070);d=md5ii(d,a,b,c,x[i+11],10,-1120210379);c=md5ii(c,d,a,b,x[i+2],15,718787259);b=md5ii(b,c,d,a,x[i+9],21,-343485551);
          a=safeAdd(a,olda);b=safeAdd(b,oldb);c=safeAdd(c,oldc);d=safeAdd(d,oldd);
        }
        return [a,b,c,d];
      }
      function str2binl(str) {
        var output = [];
        var mask = (1 << 8) - 1;
        for (var i = 0; i < str.length * 8; i += 8) {
          output[i >> 5] |= (str.charCodeAt(i / 8) & mask) << (i % 32);
        }
        return output;
      }
      function binl2hex(binarray) {
        var hexTab = '0123456789abcdef';
        var str = '';
        for (var i = 0; i < binarray.length * 4; i++) {
          str += hexTab.charAt((binarray[i >> 2] >> ((i % 4) * 8 + 4)) & 0xF) +
                 hexTab.charAt((binarray[i >> 2] >> ((i % 4) * 8)) & 0xF);
        }
        return str;
      }
      return function(string) {
        return binl2hex(binlMD5(str2binl(string), string.length * 8));
      };
    })();

    const $ = id => document.getElementById(id);
    const getDict = (key) => (window.__devtools && window.__devtools.dict) ? window.__devtools.dict[(window.__devtools.getLang())][key] || '' : '';
    const toast = () => {
      const t = $('toast');
      t.textContent = getDict('copied');
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 2000);
    };

    function hex(buffer) {
      return Array.from(new Uint8Array(buffer)).map(b => b.toString(16).padStart(2, '0')).join('');
    }

    function formatHash(hashStr) {
      return $('uppercase').checked ? hashStr.toUpperCase() : hashStr;
    }

    async function computeHashes() {
      const text = $('hashInput').value;
      if (!text) {
        $('h_md5').textContent = '—';
        $('h_sha1').textContent = '—';
        $('h_sha256').textContent = '—';
        $('h_sha512').textContent = '—';
        compareHashes();
        return;
      }

      const encoder = new TextEncoder();
      const data = encoder.encode(text);

      $('h_md5').textContent = formatHash(MD5(text));

      const [sha1Buf, sha256Buf, sha512Buf] = await Promise.all([
        crypto.subtle.digest('SHA-1', data),
        crypto.subtle.digest('SHA-256', data),
        crypto.subtle.digest('SHA-512', data),
      ]);

      $('h_sha1').textContent = formatHash(hex(sha1Buf));
      $('h_sha256').textContent = formatHash(hex(sha256Buf));
      $('h_sha512').textContent = formatHash(hex(sha512Buf));

      compareHashes();
    }

    function compareHashes() {
      const compareHash = $('compareHash').value.trim().toLowerCase();
      const resultEl = $('compareResult');
      resultEl.textContent = '';
      resultEl.className = 'hash-compare-result';

      if (!compareHash) return;

      const hashes = {
        'h_md5': $('h_md5').textContent.toLowerCase(),
        'h_sha1': $('h_sha1').textContent.toLowerCase(),
        'h_sha256': $('h_sha256').textContent.toLowerCase(),
        'h_sha512': $('h_sha512').textContent.toLowerCase(),
      };

      let matched = false;
      Object.values(hashes).forEach(h => {
        if (h !== '—' && h === compareHash) matched = true;
      });

      if (matched) {
        resultEl.textContent = '✓ ' + getDict('lbl_match');
        resultEl.className = 'hash-compare-result hash-match';
      } else if ($('hashInput').value) {
        resultEl.textContent = '✗ ' + getDict('lbl_mismatch');
        resultEl.className = 'hash-compare-result hash-mismatch';
      }
    }

    $('hashInput').addEventListener('input', computeHashes);
    $('uppercase').addEventListener('change', computeHashes);

    $('compareToggle').addEventListener('change', () => {
      $('compareArea').style.display = $('compareToggle').checked ? 'block' : 'none';
      compareHashes();
    });

    $('compareHash').addEventListener('input', compareHashes);

    document.querySelectorAll('.hex-copy').forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.getAttribute('data-target');
        const el = $(target);
        if (el && el.textContent && el.textContent !== '—') { navigator.clipboard.writeText(el.textContent); toast(); }
      });
    });

    document.getElementById('langBtn').addEventListener('click', () => {
      setTimeout(() => { compareHashes(); }, 20);
    });
  </script>
</BaseLayout>
