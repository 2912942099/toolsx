---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Password Generator" description="Generate strong, secure random passwords. Customize length and character types.">
  <div class="tool-page">
    <div class="tool-header">
      <h1 data-t="pw_title">Password Generator</h1>
      <p data-t="pw_desc">Generate secure random passwords with customizable options.</p>
    </div>

    <div style="background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); padding:24px; margin-bottom:16px;">
      <input type="text" id="result" readonly placeholder="Click Generate" style="font-size:18px; text-align:center; letter-spacing:0.05em; margin-bottom:20px; border-color:var(--accent);" data-t-ph="ph_pw_result" />

      <div class="option-row" style="margin-bottom:20px;">
        <label data-t="opt_length">Length</label>
        <span id="lenVal" style="font-size:20px; font-weight:700; font-family:var(--font-mono); min-width:36px; text-align:center;">16</span>
        <input type="range" id="length" min="4" max="64" value="16" />
      </div>
      <div class="option-row"><input type="checkbox" id="optUpper" checked /><label for="optUpper" data-t="opt_upper">Uppercase (A–Z)</label></div>
      <div class="option-row"><input type="checkbox" id="optLower" checked /><label for="optLower" data-t="opt_lower">Lowercase (a–z)</label></div>
      <div class="option-row"><input type="checkbox" id="optNum" checked /><label for="optNum" data-t="opt_numbers">Numbers (0–9)</label></div>
      <div class="option-row"><input type="checkbox" id="optSym" checked /><label for="optSym" data-t="opt_symbols">Symbols (!@#$%...)</label></div>
    </div>

    <div class="btn-group">
      <button class="btn" id="genBtn" data-t="btn_generate">Generate</button>
      <button class="btn" id="copyBtn" data-t="btn_copy">Copy Output</button>
    </div>
    <div id="error" class="error-msg"></div>

    <section class="tool-info">
      <h2 data-t="pw_about">Why Use a Strong Password?</h2>
      <p data-t="pw_about_text">A strong password should be at least 12 characters long with a mix of uppercase, lowercase, numbers, and symbols. This generator uses the crypto.getRandomValues() API for cryptographic randomness.</p>
      <h3 data-t="pw_how_title">How to Use</h3>
      <p data-t="pw_how_text">Set your desired password length using the slider. Check the character types you want to include: uppercase letters, lowercase letters, numbers, and symbols. Click "Generate" to create a secure random password. Click "Copy" to copy it to your clipboard.</p>
      <h3 data-t="pw_strength_title">Password Strength Tips</h3>
      <p data-t="pw_strength_text">A strong password should be at least 12 characters long and include a mix of all character types. Longer passwords are exponentially harder to crack — a 16-character password with mixed types would take billions of years to brute force with current technology. Never reuse passwords across different websites.</p>
      <h3 data-t="pw_security_title">How This Generator Works</h3>
      <p data-t="pw_security_text">This password generator uses the browser's built-in crypto.getRandomValues() API for cryptographic randomness, which is more secure than Math.random(). All generation happens locally in your browser — no data is sent to any server, ensuring your passwords remain completely private.</p>
    </section>
  </div>

  <!-- Password Generator 页面专属翻译 -->
  <script is:inline>
    (function() {
      if (window.__devtoolsMergeDict) {
        window.__devtoolsMergeDict({
          en: {
            pw_title: 'Password Generator',
            pw_desc: 'Generate secure random passwords with customizable options.',
            pw_about: 'Why Use a Strong Password?',
            pw_about_text: 'A strong password should be at least 12 characters long with a mix of uppercase, lowercase, numbers, and symbols. This generator uses the crypto.getRandomValues() API for cryptographic randomness.',
            pw_how_title: 'How to Use',
            pw_how_text: 'Set your desired password length using the slider. Check the character types you want to include: uppercase letters, lowercase letters, numbers, and symbols. Click "Generate" to create a secure random password. Click "Copy" to copy it to your clipboard.',
            pw_strength_title: 'Password Strength Tips',
            pw_strength_text: 'A strong password should be at least 12 characters long and include a mix of all character types. Longer passwords are exponentially harder to crack — a 16-character password with mixed types would take billions of years to brute force with current technology. Never reuse passwords across different websites.',
            pw_security_title: 'How This Generator Works',
            pw_security_text: 'This password generator uses the browser\'s built-in crypto.getRandomValues() API for cryptographic randomness, which is more secure than Math.random(). All generation happens locally in your browser — no data is sent to any server, ensuring your passwords remain completely private.',
            ph_pw_result: 'Click Generate',
            err_select_option: 'Select at least one option',
          },
          zh: {
            pw_title: '密码生成器',
            pw_desc: '生成安全的随机密码，支持自定义选项。',
            pw_about: '为什么要使用强密码？',
            pw_about_text: '强密码应至少 12 个字符，包含大小写字母、数字和符号。此生成器使用 crypto.getRandomValues() API 确保密码学级别的随机性。',
            pw_how_title: '如何使用',
            pw_how_text: '使用滑块设置所需的密码长度。勾选你想要包含的字符类型：大写字母、小写字母、数字和符号。点击「生成」创建安全的随机密码。点击「复制」将其复制到剪贴板。',
            pw_strength_title: '密码强度建议',
            pw_strength_text: '强密码应至少 12 个字符长，并包含所有字符类型的混合。更长的密码破解难度呈指数级增长——一个包含混合字符类型的 16 位密码用当前技术暴力破解需要数十亿年。永远不要在不同网站上重复使用密码。',
            pw_security_title: '生成器工作原理',
            pw_security_text: '此密码生成器使用浏览器内置的 crypto.getRandomValues() API 生成密码学级别的随机数，比 Math.random() 更安全。所有生成过程都在浏览器本地完成，不向任何服务器发送数据，确保你的密码完全私密。',
            ph_pw_result: '点击生成',
            err_select_option: '请至少选择一个选项',
          }
        });
        if (window.__devtools && window.__devtools.applyLang) {
          window.__devtools.applyLang(window.__devtools.getLang());
        }
      }
    })();
  </script>

  <!-- 功能逻辑 -->
  <script is:inline>
    const $ = id => document.getElementById(id);
    const getDict = (key) => (window.__devtools && window.__devtools.dict) ? window.__devtools.dict[(window.__devtools.getLang())][key] || '' : '';
    const toast = () => {
      const t = $('toast');
      t.textContent = getDict('copied');
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 2000);
    };

    $('length').addEventListener('input', () => { $('lenVal').textContent = $('length').value; });

    $('genBtn').addEventListener('click', () => {
      const len = parseInt($('length').value);
      let chars = '';
      if ($('optUpper').checked) chars += 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
      if ($('optLower').checked) chars += 'abcdefghijklmnopqrstuvwxyz';
      if ($('optNum').checked)   chars += '0123456789';
      if ($('optSym').checked)   chars += '!@#$%^&*()_+-=[]{}|;:,.<>?';
      if (!chars) { $('error').textContent = getDict('err_select_option'); return; }
      $('error').textContent = '';
      const arr = new Uint32Array(len);
      crypto.getRandomValues(arr);
      $('result').value = Array.from(arr, v => chars[v % chars.length]).join('');
    });

    $('copyBtn').addEventListener('click', () => {
      const v = $('result').value;
      if (v && !v.startsWith('Click') && !v.startsWith('点击')) { navigator.clipboard.writeText(v); toast(); }
    });

    $('genBtn').click();
  </script>
</BaseLayout>
