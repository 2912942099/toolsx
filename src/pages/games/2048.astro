---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="2048" description="Play 2048 - the classic number puzzle game. Use arrow keys or swipe to merge tiles and reach 2048.">
  <div class="tool-page">
    <div class="tool-header">
      <h1>2048</h1>
      <p data-t="g2048_desc">Use arrow keys or swipe to merge tiles and reach 2048!</p>
    </div>

    <div class="g2048-score-row">
      <div class="g2048-score-box">
        <div class="g2048-score-label" data-t="g2048_score">SCORE</div>
        <div class="g2048-score-value" id="score">0</div>
      </div>
      <div class="g2048-score-box">
        <div class="g2048-score-label" data-t="g2048_best">BEST</div>
        <div class="g2048-score-value" id="best">0</div>
      </div>
    </div>

    <div class="g2048-container" id="gameContainer">
      <div class="g2048-bg" id="bgGrid"></div>
      <div class="g2048-board" id="board"></div>
    </div>

    <div class="g2048-controls">
      <button class="btn btn-primary" id="newGameBtn" data-t="g2048_new">New Game</button>
      <button class="btn" id="clearBestBtn" data-t="g2048_clear">Clear Best</button>
    </div>

    <div id="gameOver" class="g2048-overlay" style="display:none;">
      <div class="g2048-overlay-text" data-t="g2048_over">Game Over!</div>
      <button class="btn btn-primary" id="retryBtn" data-t="g2048_retry">Try Again</button>
    </div>

    <div id="gameWin" class="g2048-overlay" style="display:none;">
      <div class="g2048-overlay-text" data-t="g2048_win">You Win!</div>
      <button class="btn" id="continueBtn" data-t="g2048_continue">Continue</button>
      <button class="btn btn-primary" id="retryBtn2" data-t="g2048_retry">Try Again</button>
    </div>

    <section class="tool-info">
      <h2 data-t="g2048_about">About 2048</h2>
      <p data-t="g2048_about_text">2048 is a single-player sliding tile puzzle game. The objective is to slide numbered tiles on a grid to combine them and create a tile with the number 2048.</p>
      <h3 data-t="g2048_how">How to Play</h3>
      <p data-t="g2048_how_text">Use the arrow keys (↑ ↓ ← →) or WASD on desktop, swipe on mobile, or drag with mouse.</p>
    </section>
  </div>

  <!-- 2048 翻译 -->
  <script is:inline>
    (function() {
      if (window.__devtoolsMergeDict) {
        window.__devtoolsMergeDict({
          en: {
            g2048_desc: 'Use arrow keys or swipe to merge tiles and reach 2048!',
            g2048_new: 'New Game',
            g2048_over: 'Game Over!',
            g2048_win: 'You Win!',
            g2048_continue: 'Continue',
            g2048_retry: 'Try Again',
            g2048_clear: 'Clear Best',
            g2048_about: 'About 2048',
            g2048_about_text: '2048 is a single-player sliding tile puzzle game. The objective is to slide numbered tiles on a grid to combine them and create a tile with the number 2048.',
            g2048_how: 'How to Play',
            g2048_how_text: 'Use the arrow keys (↑ ↓ ← →) or WASD on desktop, swipe on mobile, or drag with mouse.',
          },
          zh: {
            g2048_desc: '使用方向键或滑动合并方块，挑战 2048！',
            g2048_new: '新游戏',
            g2048_over: '游戏结束！',
            g2048_win: '你赢了！',
            g2048_continue: '继续',
            g2048_retry: '再试一次',
            g2048_clear: '清除最高分',
            g2048_about: '关于 2048',
            g2048_about_text: '2048 是一款单人滑动方块拼图游戏。目标是在网格上滑动数字方块，将相同的数字合并，最终创建出 2048 的方块。',
            g2048_how: '玩法说明',
            g2048_how_text: '桌面端使用方向键（↑ ↓ ← →）或 WASD，手机端滑动屏幕，鼠标拖拽也可以。',
          }
        });
        if (window.__devtools && window.__devtools.applyLang) {
          window.__devtools.applyLang(window.__devtools.getLang());
        }
      }
    })();
  </script>

  <!-- 2048 游戏逻辑 -->
  <script is:inline>
  (function() {
    var SIZE = 4;
    var grid = [], tiles = [], tileId = 0;
    var score = 0, best = parseInt(localStorage.getItem('g2048_best')) || 0;
    var won = false, keepPlaying = false, animating = false;

    var boardEl = document.getElementById('board');
    var containerEl = document.getElementById('gameContainer');
    var scoreEl = document.getElementById('score');
    var bestEl = document.getElementById('best');
    var gameOverEl = document.getElementById('gameOver');
    var gameWinEl = document.getElementById('gameWin');

    bestEl.textContent = best;

    // Render background grid
    var bgHtml = '';
    for (var i = 0; i < SIZE * SIZE; i++) bgHtml += '<div class="g2048-bg-tile"></div>';
    document.getElementById('bgGrid').innerHTML = bgHtml;

    function getTileColor(val) {
      var c = { 2:'#eee4da', 4:'#ede0c8', 8:'#f2b179', 16:'#f59563', 32:'#f67c5f', 64:'#f65e3b', 128:'#edcf72', 256:'#edcc61', 512:'#edc850', 1024:'#edc53f', 2048:'#edc22e' };
      return c[val] || '#3c3a32';
    }

    function getTextColor(val) { return val <= 4 ? '#776e65' : '#f9f6f2'; }

    function setTilePos(el, r, c) {
      el.style.left = 'calc(' + c + ' * 25% + ' + (c * 2) + 'px)';
      el.style.top = 'calc(' + r + ' * 25% + ' + (r * 2) + 'px)';
    }

    function createTileEl(val, r, c) {
      var el = document.createElement('div');
      el.className = 'g2048-tile g2048-tile-new';
      setTilePos(el, r, c);
      applyTileStyle(el, val);
      el.textContent = val;
      return el;
    }

    function applyTileStyle(el, val) {
      el.style.background = getTileColor(val);
      el.style.color = getTextColor(val);
      el.style.fontSize = val >= 1024 ? '16px' : val >= 128 ? '20px' : '24px';
    }

    function init() {
      grid = []; tiles = []; tileId = 0; score = 0;
      won = false; keepPlaying = false; animating = false;
      boardEl.innerHTML = '';
      for (var r = 0; r < SIZE; r++) { grid[r] = []; for (var c = 0; c < SIZE; c++) grid[r][c] = 0; }
      scoreEl.textContent = '0';
      gameOverEl.style.display = 'none';
      gameWinEl.style.display = 'none';
      addRandomTile();
      addRandomTile();
    }

    function addRandomTile() {
      var empty = [];
      for (var r = 0; r < SIZE; r++)
        for (var c = 0; c < SIZE; c++)
          if (grid[r][c] === 0) empty.push({r:r, c:c});
      if (empty.length === 0) return null;
      var spot = empty[Math.floor(Math.random() * empty.length)];
      var val = Math.random() < 0.9 ? 2 : 4;
      grid[spot.r][spot.c] = val;
      var tile = { id: tileId++, val: val, row: spot.r, col: spot.c, el: createTileEl(val, spot.r, spot.c) };
      boardEl.appendChild(tile.el);
      tiles.push(tile);
      return tile;
    }

    function removeTile(tile) {
      if (tile.el && tile.el.parentNode) tile.el.parentNode.removeChild(tile.el);
    }

    function getTileAt(r, c) {
      for (var i = 0; i < tiles.length; i++)
        if (tiles[i].row === r && tiles[i].col === c) return tiles[i];
      return null;
    }

    function getVector(dir) {
      if (dir === 'up') return {r:-1, c:0};
      if (dir === 'down') return {r:1, c:0};
      if (dir === 'left') return {r:0, c:-1};
      if (dir === 'right') return {r:0, c:1};
    }

    function getTraversalOrder(dir) {
      var pos = [];
      for (var r = 0; r < SIZE; r++)
        for (var c = 0; c < SIZE; c++)
          pos.push({r:r, c:c});
      if (dir === 'left') pos.sort(function(a,b){ return a.c - b.c; });
      if (dir === 'right') pos.sort(function(a,b){ return b.c - a.c; });
      if (dir === 'up') pos.sort(function(a,b){ return a.r - b.r; });
      if (dir === 'down') pos.sort(function(a,b){ return b.r - a.r; });
      return pos;
    }

    function updateScore() {
      scoreEl.textContent = score;
      if (score > best) {
        best = score;
        bestEl.textContent = best;
        localStorage.setItem('g2048_best', best);
      }
    }

    function hasWon() {
      for (var i = 0; i < tiles.length; i++) if (tiles[i].val >= 2048) return true;
      return false;
    }

    function canMove() {
      for (var r = 0; r < SIZE; r++)
        for (var c = 0; c < SIZE; c++) {
          if (grid[r][c] === 0) return true;
          if (c + 1 < SIZE && grid[r][c] === grid[r][c+1]) return true;
          if (r + 1 < SIZE && grid[r][c] === grid[r+1][c]) return true;
        }
      return false;
    }

    function doMove(dir) {
      if (animating) return;
      animating = true;

      var vector = getVector(dir);
      var order = getTraversalOrder(dir);
      var moved = false;
      var merged = [];
      var newGrid = [];
      for (var r = 0; r < SIZE; r++) { newGrid[r] = []; for (var c = 0; c < SIZE; c++) newGrid[r][c] = null; }

      for (var idx = 0; idx < order.length; idx++) {
        var pos = order[idx];
        var tile = getTileAt(pos.r, pos.c);
        if (!tile) continue;

        var r = pos.r, c = pos.c;
        var nr = r + vector.r, nc = c + vector.c;

        while (nr >= 0 && nr < SIZE && nc >= 0 && nc < SIZE && newGrid[nr][nc] === null) {
          r = nr; c = nc;
          nr = r + vector.r; nc = c + vector.c;
        }

        if (nr >= 0 && nr < SIZE && nc >= 0 && nc < SIZE) {
          var target = newGrid[nr][nc];
          if (target && target.val === tile.val && !target._merged) {
            target.val *= 2; target._merged = true; score += target.val;
            merged.push({keeper: target, removed: tile});
            tile._newRow = nr; tile._newCol = nc; moved = true; continue;
          }
        }

        newGrid[r][c] = tile;
        tile._newRow = r; tile._newCol = c;
        if (r !== pos.r || c !== pos.c) moved = true;
      }

      if (!moved) {
        tiles.forEach(function(t){ delete t._newRow; delete t._newCol; delete t._merged; });
        animating = false; return;
      }

      // Animate slide
      tiles.forEach(function(t) { setTilePos(t.el, t._newRow, t._newCol); });

      setTimeout(function() {
        // Remove merged-away tiles
        var removedIds = {};
        merged.forEach(function(m) { removedIds[m.removed.id] = true; removeTile(m.removed); });
        tiles = tiles.filter(function(t) { return !removedIds[t.id]; });

        // Update merged keeper tiles with pop animation
        merged.forEach(function(m) {
          m.keeper.el.className = 'g2048-tile';
          void m.keeper.el.offsetWidth;
          applyTileStyle(m.keeper.el, m.keeper.val);
          m.keeper.el.textContent = m.keeper.val;
          m.keeper.el.className = 'g2048-tile g2048-tile-merged';
        });

        // Update grid
        for (var r = 0; r < SIZE; r++) for (var c = 0; c < SIZE; c++) grid[r][c] = 0;
        tiles.forEach(function(t) {
          t.row = t._newRow; t.col = t._newCol;
          grid[t.row][t.col] = t.val;
          delete t._newRow; delete t._newCol; delete t._merged;
        });

        updateScore();
        addRandomTile();

        if (!won && hasWon()) { won = true; setTimeout(function(){ gameWinEl.style.display = 'flex'; }, 300); }
        if (!canMove()) { setTimeout(function(){ gameOverEl.style.display = 'flex'; }, 300); }
        animating = false;
      }, 150);
    }

    // Keyboard: Arrow + WASD
    document.addEventListener('keydown', function(e) {
      var dir = null;
      if (e.key === 'ArrowLeft' || e.key === 'a' || e.key === 'A') dir = 'left';
      if (e.key === 'ArrowRight' || e.key === 'd' || e.key === 'D') dir = 'right';
      if (e.key === 'ArrowUp' || e.key === 'w' || e.key === 'W') dir = 'up';
      if (e.key === 'ArrowDown' || e.key === 's' || e.key === 'S') dir = 'down';
      if (dir) { e.preventDefault(); doMove(dir); }
    });

    // Touch
    var touchStartX, touchStartY;
    containerEl.addEventListener('touchstart', function(e) {
      touchStartX = e.touches[0].clientX; touchStartY = e.touches[0].clientY;
    }, { passive: true });
    containerEl.addEventListener('touchend', function(e) {
      if (!touchStartX) return;
      var dx = e.changedTouches[0].clientX - touchStartX;
      var dy = e.changedTouches[0].clientY - touchStartY;
      if (Math.max(Math.abs(dx), Math.abs(dy)) < 20) return;
      if (Math.abs(dx) > Math.abs(dy)) doMove(dx > 0 ? 'right' : 'left');
      else doMove(dy > 0 ? 'down' : 'up');
      touchStartX = null;
    }, { passive: true });

    // Mouse drag
    var mouseDown = false, mouseStartX, mouseStartY;
    containerEl.addEventListener('mousedown', function(e) {
      mouseDown = true; mouseStartX = e.clientX; mouseStartY = e.clientY; e.preventDefault();
    });
    document.addEventListener('mouseup', function(e) {
      if (!mouseDown) return; mouseDown = false;
      var dx = e.clientX - mouseStartX, dy = e.clientY - mouseStartY;
      if (Math.max(Math.abs(dx), Math.abs(dy)) < 20) return;
      if (Math.abs(dx) > Math.abs(dy)) doMove(dx > 0 ? 'right' : 'left');
      else doMove(dy > 0 ? 'down' : 'up');
    });

    // Buttons
    document.getElementById('newGameBtn').addEventListener('click', init);
    document.getElementById('retryBtn').addEventListener('click', init);
    document.getElementById('retryBtn2').addEventListener('click', init);
    document.getElementById('continueBtn').addEventListener('click', function() {
      keepPlaying = true; gameWinEl.style.display = 'none';
    });
    document.getElementById('clearBestBtn').addEventListener('click', function() {
      best = 0; bestEl.textContent = '0'; localStorage.removeItem('g2048_best');
      bestEl.style.color = '#ef4444'; bestEl.style.transform = 'scale(1.4)';
      bestEl.style.transition = 'all 0.3s ease';
      setTimeout(function(){ bestEl.style.color = ''; bestEl.style.transform = ''; }, 500);
    });

    init();
  })();
  </script>
</BaseLayout>
