---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Regex Tester" description="Test regular expressions with real-time matching and highlighting. Free online tool.">
  <div class="tool-page">
    <div class="tool-header">
      <h1 data-t="regex_title">Regex Tester</h1>
      <p data-t="regex_desc">Test regular expressions with real-time matching and highlighting.</p>
    </div>

    <div class="regex-pattern-row">
      <span class="regex-slash">/</span>
      <input type="text" id="pattern" placeholder="e.g. hello" data-t-ph="ph_regex_pattern" spellcheck="false" autocomplete="off" />
      <span class="regex-slash">/</span>
      <div class="regex-flags">
        <label class="regex-flag"><input type="checkbox" id="flagG" checked /><span>g</span></label>
        <label class="regex-flag"><input type="checkbox" id="flagI" /><span>i</span></label>
        <label class="regex-flag"><input type="checkbox" id="flagM" /><span>m</span></label>
        <label class="regex-flag"><input type="checkbox" id="flagS" /><span>s</span></label>
      </div>
    </div>
    <div id="error" class="error-msg"></div>

    <div style="margin-top:16px;">
      <div class="editor-label" data-t="lbl_test_string">Test String</div>
      <textarea id="testString" placeholder="Type or paste your test string here..." data-t-ph="ph_regex_test" spellcheck="false" style="min-height:180px"></textarea>
    </div>

    <div id="highlightResult" class="regex-highlight-box"></div>

    <div class="stats" id="matchStats" style="display:none;">
      <div class="stat-item">
        <div class="stat-value" id="matchCount">0</div>
        <div class="stat-label" data-t="lbl_match_count">Matches</div>
      </div>
    </div>
    <div id="noMatch" class="regex-no-match" style="display:none;"></div>

    <div id="matchDetails" class="regex-details"></div>

    <section class="tool-info">
      <h2 data-t="regex_about">About Regular Expressions</h2>
      <p data-t="regex_about_text">A regular expression (regex) is a sequence of characters that defines a search pattern. This tool tests your regex pattern in real time and shows all matches with their positions and captured groups.</p>
      <h3 data-t="regex_how_title">How to Use</h3>
      <p data-t="regex_how_text">Enter your regular expression pattern in the top field between the slashes. Type or paste your test string in the text area below. Matches are highlighted in real time with details shown below including match position and capture groups.</p>
      <h3 data-t="regex_flags_title">Understanding Flags</h3>
      <p data-t="regex_flags_text">The g (global) flag finds all matches instead of stopping at the first one. The i (insensitive) flag makes the pattern case-insensitive. The m (multiline) flag makes ^ and $ match the start and end of each line. The s (dotAll) flag makes the dot (.) also match newline characters.</p>
      <h3 data-t="regex_uses_title">Common Use Cases</h3>
      <p data-t="regex_uses_text">Data validation (emails, phone numbers, URLs). Find and replace in text editors and IDEs. Log file parsing and analysis. Web scraping and data extraction. Input sanitization and format checking in web forms.</p>
    </section>
  </div>

  <!-- Regex Tester 页面专属翻译 -->
  <script is:inline>
    (function() {
      if (window.__devtoolsMergeDict) {
        window.__devtoolsMergeDict({
          en: {
            regex_title: 'Regex Tester',
            regex_desc: 'Test regular expressions with real-time matching and highlighting.',
            regex_about: 'About Regular Expressions',
            regex_about_text: 'A regular expression (regex) is a sequence of characters that defines a search pattern. This tool tests your regex pattern in real time and shows all matches with their positions and captured groups.',
            regex_how_title: 'How to Use',
            regex_how_text: 'Enter your regular expression pattern in the top field between the slashes. Type or paste your test string in the text area below. Matches are highlighted in real time with details shown below including match position and capture groups.',
            regex_flags_title: 'Understanding Flags',
            regex_flags_text: 'The g (global) flag finds all matches instead of stopping at the first one. The i (insensitive) flag makes the pattern case-insensitive. The m (multiline) flag makes ^ and $ match the start and end of each line. The s (dotAll) flag makes the dot (.) also match newline characters.',
            regex_uses_title: 'Common Use Cases',
            regex_uses_text: 'Data validation (emails, phone numbers, URLs). Find and replace in text editors and IDEs. Log file parsing and analysis. Web scraping and data extraction. Input sanitization and format checking in web forms.',
            ph_regex_pattern: 'e.g. \\b\\w+@\\w+\\.\\w+\\b',
            ph_regex_test: 'Type or paste your test string here...',
            err_regex_invalid: 'Invalid regular expression',
          },
          zh: {
            regex_title: '正则测试',
            regex_desc: '正则表达式实时匹配和高亮测试。',
            regex_about: '关于正则表达式',
            regex_about_text: '正则表达式（regex）是一组定义搜索模式的字符序列。用于字符串匹配、搜索和文本处理。此工具实时测试你的正则模式，显示所有匹配项及其位置和捕获组。所有处理在浏览器端完成。',
            regex_how_title: '如何使用',
            regex_how_text: '在顶部的斜杠之间输入正则表达式。在下方的文本区域输入或粘贴测试文本。匹配项会实时高亮显示，并在下方显示匹配位置和捕获组等详细信息。',
            regex_flags_title: '理解标志',
            regex_flags_text: 'g（全局）标志查找所有匹配项，而不是在第一个就停止。i（忽略大小写）标志使模式不区分大小写。m（多行）标志使 ^ 和 $ 匹配每行的开头和结尾。s（dotAll）标志使点号（.）也能匹配换行符。',
            regex_uses_title: '常见用途',
            regex_uses_text: '数据验证（邮箱、电话号码、URL）。文本编辑器和 IDE 中的查找替换。日志文件解析和分析。网页爬虫和数据提取。Web 表单中的输入清理和格式检查。',
            ph_regex_pattern: '例如 \\b\\w+@\\w+\\.\\w+\\b',
            ph_regex_test: '输入或粘贴测试文本...',
            err_regex_invalid: '无效的正则表达式',
          }
        });
        if (window.__devtools && window.__devtools.applyLang) {
          window.__devtools.applyLang(window.__devtools.getLang());
        }
      }
    })();
  </script>

  <!-- 功能逻辑 -->
  <script is:inline>
  (function(){
    var RE = {};

    RE.getLang = function() {
      return (window.__devtools && window.__devtools.getLang) ? window.__devtools.getLang() : 'en';
    };

    RE.getDict = function(key) {
      return (window.__devtools && window.__devtools.dict) ? window.__devtools.dict[RE.getLang()][key] || '' : '';
    };

    RE.init = function() {
      RE.patternEl = document.getElementById('pattern');
      RE.testEl = document.getElementById('testString');
      RE.errorEl = document.getElementById('error');
      RE.highlightEl = document.getElementById('highlightResult');
      RE.statsEl = document.getElementById('matchStats');
      RE.noMatchEl = document.getElementById('noMatch');
      RE.countEl = document.getElementById('matchCount');
      RE.detailsEl = document.getElementById('matchDetails');

      RE.patternEl.oninput = RE.run;
      RE.testEl.oninput = RE.run;
      document.getElementById('flagG').onchange = RE.run;
      document.getElementById('flagI').onchange = RE.run;
      document.getElementById('flagM').onchange = RE.run;
      document.getElementById('flagS').onchange = RE.run;

      document.getElementById('langBtn').onclick = function() {
        setTimeout(function() {
          RE.run();
        }, 20);
      };
    };

    RE.esc = function(s) {
      return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    };

    RE.run = function() {
      var p = RE.patternEl.value;
      var t = RE.testEl.value;

      RE.detailsEl.innerHTML = '';
      RE.statsEl.style.display = 'none';
      RE.noMatchEl.style.display = 'none';
      RE.noMatchEl.textContent = '';
      RE.highlightEl.innerHTML = '';
      RE.highlightEl.style.display = 'none';
      RE.errorEl.textContent = '';

      if (!p) return;

      if (!t) {
        var z = RE.getLang() === 'zh';
        RE.errorEl.textContent = z ? '请在下方输入测试文本' : 'Please enter test string below';
        return;
      }

      var flags = '';
      if (document.getElementById('flagG').checked) flags += 'g';
      if (document.getElementById('flagI').checked) flags += 'i';
      if (document.getElementById('flagM').checked) flags += 'm';
      if (document.getElementById('flagS').checked) flags += 's';

      var re;
      try { re = new RegExp(p, flags); } catch(e) {
        RE.errorEl.textContent = RE.getDict('err_regex_invalid') || 'Invalid regex';
        return;
      }

      var matches = [];
      if (flags.indexOf('g') >= 0) {
        var m, r2 = new RegExp(p, flags);
        while ((m = r2.exec(t)) !== null) {
          matches.push({v:m[0], i:m.index, g:m.slice(1)});
          if (m[0].length === 0) r2.lastIndex++;
          if (matches.length > 5000) break;
        }
      } else {
        var m = re.exec(t);
        if (m) matches.push({v:m[0], i:m.index, g:m.slice(1)});
      }

      RE.countEl.textContent = matches.length;
      RE.statsEl.style.display = matches.length > 0 ? 'flex' : 'none';

      if (matches.length === 0) {
        var z = RE.getLang() === 'zh';
        RE.noMatchEl.textContent = z ? '未找到匹配项' : 'No matches found';
        RE.noMatchEl.style.display = 'block';
      }

      if (matches.length > 0) {
        var html = '', last = 0;
        for (var x = 0; x < matches.length; x++) {
          if (matches[x].i < last) continue;
          html += RE.esc(t.slice(last, matches[x].i));
          html += '<mark>' + RE.esc(matches[x].v) + '</mark>';
          last = matches[x].i + matches[x].v.length;
        }
        html += RE.esc(t.slice(last));
        RE.highlightEl.innerHTML = html;
        RE.highlightEl.style.display = 'block';

        var z = RE.getLang() === 'zh';
        var dh = '';
        for (var x = 0; x < matches.length; x++) {
          var mm = matches[x];
          dh += '<div class="regex-detail-card">';
          dh += '<div class="regex-detail-header">';
          dh += '<span class="regex-detail-idx">#' + (x+1) + '</span>';
          dh += '<span class="regex-detail-pos">' + (z ? '位置' : 'Position') + ': ' + mm.i + ' – ' + (mm.i + mm.v.length) + '</span>';
          dh += '</div>';
          dh += '<div class="regex-detail-match"><span class="regex-detail-key">' + (z ? '匹配' : 'Match') + ':</span> <code>' + RE.esc(mm.v) + '</code></div>';
          for (var gi = 0; gi < mm.g.length; gi++) {
            dh += '<div class="regex-detail-match"><span class="regex-detail-key">' + (z ? '分组' : 'Group') + ' ' + (gi+1) + ':</span> <code>' + (mm.g[gi] !== undefined ? RE.esc(mm.g[gi]) : 'undefined') + '</code></div>';
          }
          dh += '</div>';
        }
        RE.detailsEl.innerHTML = dh;
      }
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', RE.init);
    } else {
      RE.init();
    }
  })();
  </script>
</BaseLayout>
