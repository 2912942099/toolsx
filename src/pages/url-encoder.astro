---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="URL Encoder / Decoder" description="Encode and decode URLs and URI components online. Free browser-based tool.">
  <div class="tool-page">
    <div class="tool-header">
      <h1 data-t="url_title">URL Encoder / Decoder</h1>
      <p data-t="url_desc">Encode or decode URLs and URI components.</p>
    </div>

    <div class="editor-row">
      <div>
        <div class="editor-label" data-t="input_label">Input</div>
        <textarea id="input" placeholder="https://example.com/path?q=helloworld" data-t-ph="ph_url_input"></textarea>
      </div>
      <div>
        <div class="editor-label" data-t="output_label">Output</div>
        <textarea id="output" readonly placeholder="Result..." data-t-ph="ph_url_output"></textarea>
      </div>
    </div>

    <div class="btn-group">
      <button class="btn" id="encodeUri" data-t="btn_encode_uri">Encode URI</button>
      <button class="btn" id="encodeComp" data-t="btn_encode_comp">Encode Component</button>
      <button class="btn" id="decodeBtn" data-t="btn_decode">← Decode</button>
      <button class="btn" id="copyBtn" data-t="btn_copy">Copy Output</button>
      <button class="btn" id="clearBtn" data-t="btn_clear">Clear</button>
    </div>
    <div id="error" class="error-msg"></div>

    <section class="tool-info">
      <h2 data-t="url_about">About URL Encoding</h2>
      <p data-t="url_about_text">URL encoding replaces unsafe ASCII characters with a percent sign followed by two hexadecimal digits. Encode URI preserves URL structure. Encode Component encodes everything — useful for query parameter values.</p>
    
      <h3 data-t="url_how_title">How to Use</h3>
<p data-t="url_how_text">Enter or paste a URL in the input field. Use "Encode URI" to encode special characters while preserving the URL structure, or "Encode Component" to encode everything. Use "Decode" to convert an encoded URL back to its original form.</p>
<h3 data-t="url_what_title">What is URL Encoding?</h3>
<p data-t="url_what_text">URL encoding (also called percent-encoding) converts characters into a format that can be safely transmitted over the Internet. Unsafe characters are replaced with a percent sign (%) followed by two hexadecimal digits. For example, a space becomes %20.</p>
<h3 data-t="url_diff_title">Encode URI vs Encode Component</h3>
<p data-t="url_diff_text">Encode URI preserves the structure of a URL (keeps :, /, ?, #, etc.) and is suitable for encoding a complete URL. Encode Component encodes everything including special URL characters, making it ideal for encoding individual parameter values in a query string.</p>

    </section>
  </div>

  <script is:inline>
    const $ = id => document.getElementById(id);
    const getLang = () => (window.__devtools && window.__devtools.getLang) ? window.__devtools.getLang() : 'en';
    const getDict = (key) => (window.__devtools && window.__devtools.dict) ? window.__devtools.dict[getLang()][key] || '' : '';
    const toast = () => {
      const t = $('toast');
      t.textContent = getDict('copied');
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 2000);
    };

    let currentError = null;
    function showError(key, detail) {
      if (key === null) { $('error').textContent = ''; currentError = null; return; }
      currentError = { key, detail };
      let text = getDict(key) || key;
      if (detail) text += ': ' + detail;
      $('error').textContent = text;
    }

    document.getElementById('langBtn').addEventListener('click', () => {
      setTimeout(() => { if (currentError) showError(currentError.key, currentError.detail); }, 20);
    });

    $('encodeUri').addEventListener('click', () => { showError(null); try { $('output').value = encodeURI($('input').value); } catch (e) { showError('err_encode_fail', e.message); } });
    $('encodeComp').addEventListener('click', () => { showError(null); try { $('output').value = encodeURIComponent($('input').value); } catch (e) { showError('err_encode_fail', e.message); } });
    $('decodeBtn').addEventListener('click', () => { showError(null); try { $('output').value = decodeURIComponent($('input').value); } catch (e) { showError('err_invalid_url'); } });
    $('copyBtn').addEventListener('click', () => { if ($('output').value) { navigator.clipboard.writeText($('output').value); toast(); } });
    $('clearBtn').addEventListener('click', () => { $('input').value = ''; $('output').value = ''; showError(null); });
  </script>
</BaseLayout>
